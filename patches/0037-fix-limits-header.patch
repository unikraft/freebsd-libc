 #ifndef _LIMITS_H_
 #define	_LIMITS_H_
 
 #include <sys/cdefs.h>
 #include <sys/_types.h>
 
-#ifndef _GID_T_DECLARED
-typedef	__gid_t		gid_t;
-#define	_GID_T_DECLARED
-#endif
-
